{
  "name": "WVH Koersapp",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20",
  "features": {},
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "WVH Koersapp",
      "onAutoForward": "openBrowser"
    }
  },
  "postCreateCommand": "cp -n .env.example .env && npm install --ignore-scripts && npx prisma generate && npx prisma db push --skip-generate && npx tsx prisma/seed.ts",
  "postAttachCommand": "npm run dev",
  "customizations": {
    "vscode": {
      "extensions": [
        "Prisma.prisma",
        "bradlc.vscode-tailwindcss",
        "dbaeumer.vscode-eslint"
      ]
    }
  }
}
