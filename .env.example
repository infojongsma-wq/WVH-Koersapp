# Database — Postgres. On Vercel this is auto-set by the Postgres integration.
DATABASE_URL="postgres://user:pass@host:5432/wvh_koersapp"

# Session secret — generate a long random string. On Vercel set this yourself.
SESSION_SECRET="change-me-in-production-use-a-long-random-string"

# Admin bootstrap: comma-separated e-mail addresses. These are auto-added to
# the whitelist and get the ADMIN role on first login.
ADMIN_EMAILS="infojongsma@gmail.com"

# Base URL, used only if you want to render absolute links in logs.
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# E-mail (magic links). Leave empty to fall back to an on-screen login link.
# For Gmail: turn on 2-Step Verification, then create an "App password".
# SMTP_USER="infojongsma@gmail.com"
# SMTP_PASS="the-16-char-app-password"
# MAIL_FROM="WVH Koersapp <infojongsma@gmail.com>"
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="465"
